  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check": "node ../scripts/check.js",
    "lint": "eslint --no-eslintrc --config ../.eslintrc.cjs \"../Server/**/*.js\" \"../scripts/**/*.js\" \"../Client/**/*.js\"",
